# AI Signal — Environment Variables
# Copy contents into .env.local (project root) and fill in real values.
# This file is committed to git. .env.local is gitignored — never commit it.

# ── Supabase ──────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site URL (used for magic link email redirect) ─────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI / LLM ─────────────────────────────────────────────────────────
# Priority 1: Anthropic (Claude Sonnet for Scorer/Writer, Haiku for Personalizer)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Priority 2: Google Gemini (fallback)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ── Email ─────────────────────────────────────────────────────────────
# Resend — transactional (welcome, upgrade, alerts)
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# Beehiiv — newsletter delivery
# Get from: https://app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ── Payments ──────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_REPLACE
# Get from: Stripe → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ── Job Queue (Inngest) ───────────────────────────────────────────────
# Get from: https://app.inngest.com → Settings → Event Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Analytics ─────────────────────────────────────────────────────────
# Get from: https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
