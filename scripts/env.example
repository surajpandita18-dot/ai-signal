# AI Signal — environment variable reference
# Copy contents into .env.local (project root) and fill in real values.
# Or run: bash scripts/setup-env.sh
#
# This file (scripts/env.example) is committed to git.
# .env.local is gitignored — never commit it.

# ── PostHog ──────────────────────────────────────────────────────
# Get from: https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── LLM Provider (at least one required for process-signals.mjs) ─
#
# Priority 1: Anthropic (Claude Sonnet for #1-3, Haiku for #4-25)
# Get from: https://console.anthropic.com → API Keys
# Also add as GitHub Actions secret named: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
#
# Priority 2: Google Gemini (fallback when ANTHROPIC_API_KEY missing)
# Model: gemini-1.5-flash — same prompt, same output format, same cache
# Get from: https://aistudio.google.com/app/apikey
# Also add as GitHub Actions secret named: GEMINI_API_KEY
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ── NextAuth ─────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_-base64_32
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App — create at: https://github.com/settings/applications/new
# Application name: AI Signal (dev)
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=YOUR_GITHUB_OAUTH_APP_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_OAUTH_APP_CLIENT_SECRET
